---
layout: layout.njk
---
<article class="post-content">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time class="post-date" datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>
  <p class="post-back"><a href="/posts/">← All posts</a></p>
</article>
